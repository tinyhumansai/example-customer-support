# ─── Neocortex Memory SDK ───────────────────────────────────────────
# Required for all memory operations (ingest, recall, delete).
# Generate your token and model ID at https://app.tinyhumans.ai
#   1. Sign up / log in
#   2. Create a new project (or use an existing one)
#   3. Go to Settings > API Keys > Generate
#   4. Copy the token and model ID below
TINYHUMANS_TOKEN=
TINYHUMANS_MODEL_ID=

# ─── OpenAI ─────────────────────────────────────────────────────────
# Required for AI-generated responses (used by recall_with_llm).
# Get your key at https://platform.openai.com/api-keys
# Note: only needed for pages that generate LLM responses (2-5).
#       Seeding data (page 1) works without this.
OPENAI_API_KEY=
